# ── Jupiter Prediction V3 — environment ────────────────────────────────────
# Copy to .env and fill. NEVER commit .env. No private keys are required or used.

# Jupiter Prediction API key (sent as x-api-key header). REQUIRED for live data.
JUPITER_API_KEY=

# ── Safety flags (ALL default to the safe value if unset) ───────────────────
# These OVERRIDE config/jupiter_prediction.yaml. Live trading requires the
# explicit unsafe combination READ_ONLY=false + DRY_RUN=false + ENABLE_LIVE_TRADING=true.
READ_ONLY=true
DRY_RUN=true
ENABLE_LIVE_TRADING=false

# ── Optional: BTC context (secondary features only) ─────────────────────────
# MoonDev / CEX order-flow API. Used ONLY for secondary features (CVD,
# liquidations, momentum). NEVER used as the primary settlement price.
MOONDEV_API_KEY=

# ── Optional: research-only CEX fallback pricing ────────────────────────────
# When true, allows generic CEX price as a LOW-CONFIDENCE settlement fallback
# for research. Must stay false for any pricing you would trust.
ALLOW_CEX_RESEARCH_FALLBACK=false

# Path to config file (optional override)
JUPITER_CONFIG_PATH=config/jupiter_prediction.yaml
